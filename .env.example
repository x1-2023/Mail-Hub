# --- SERVER CONFIG ---
PORT=8080       # Internal Container Port (Keep as 8080)
API_PORT=3000   # External Host Port (User requested 3000)
SMTP_PORT=2525  # External Host Port
WEB_PORT=4000   # External Host Port (User requested 4000)

# --- SECURITY ---
NEXTAUTH_SECRET="changeme_super_secret_string"
JWT_SECRET="changeme_random_long_string_for_jwt_signing"

# --- DATABASE (Local / External) ---
# If running locally without Docker, use this:
DATABASE_URL="host=localhost user=postgres password=postgres dbname=mailhub port=5432 sslmode=disable TimeZone=Asia/Ho_Chi_Minh"
REDIS_ADDR="localhost:6379"

# --- DOCKER DATABASE CONFIG (Auto-used by docker-compose) ---
DB_USER=mailuser
DB_PASSWORD=changeme_secure_password
DB_NAME=maildb

# --- DOMAIN CONFIG ---
DOMAIN=example.com

# --- FRONTEND CONFIG ---
# Warning: These variables are baked into the Docker image at build time!
# If your API is on a different domain, change this before 'docker-compose build'
# Set to the PUBLIC URL of your API (Nginx Proxy Manager Domain)
VITE_API_URL=https://api.example.com/api
